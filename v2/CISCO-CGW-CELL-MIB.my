ciscoCgwCellSimEntry OBJECT-TYPE
    SYNTAX          CiscoCgwCellSimEntry
    MAX-ACCESS      not-accessible
    STATUS          current
    DESCRIPTION
        "An entry (conceptual row) in the ciscoCgwCellSimTable."
    INDEX      { entPhysicalIndex }
    ::= { ciscoCgwCellSimTable 1 }

ciscoCgwCellRadioEntry OBJECT-TYPE
    SYNTAX          CiscoCgwCellRadioEntry
    MAX-ACCESS      not-accessible
    STATUS          current
    DESCRIPTION
        "An entry (conceptual row) in the ciscoCgwCellRadioTable."
    INDEX           { entPhysicalIndex }
    ::= { ciscoCgwCellRadioTable 1 }

ciscoCgwCell5GNRBandEntry OBJECT-TYPE
    SYNTAX          CiscoCgwCell5GNRBandEntry 
    MAX-ACCESS      not-accessible
    STATUS          current
    DESCRIPTION
        "An entry (conceptual row) in the ciscoCgwCell5GNRBandTable."
    INDEX           { entPhysicalIndex, cgwCell5GNRBandCarrierIndex }
    ::= { ciscoCgwCell5GNRBandTable 1 }

CiscoCgwCellModemEntry ::=
    SEQUENCE {
        ciscoCgwCellFirmwareVersion 	    String,
        ciscoCgwCellHostFirmwareVersion     String,
        ciscoCgwCellModelID                 String,
        ciscoCgwCellIMSI                    String,
        ciscoCgwCellIMEI                    String,
        ciscoCgwCellICCID                   String,
        ciscoCgwCellMSISDN                  String,
        ciscoCgwCellFSN                     String,
        ciscoCgwCellModemTemperature        Byte,
        ciscoCgwCellPRISKUID                String,
        ciscoCgwCellPRIVersion              String,
        ciscoCgwCellCarrier                 String,
        ciscoCgwCellOEMPRIVersion           String,
        ciscoCgwCellModemStatus             String
    }


ciscoCgwCellFirmwareVersion OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Modem Firmware Version"
    ::= { ciscoCgwCellModemEntry 1 }

ciscoCgwCellHostFirmwareVersion OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Host Firmware Version"
    ::= { ciscoCgwCellModemEntry 2 }

ciscoCgwCellModelID OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
