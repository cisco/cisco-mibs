    STATUS     current
    DESCRIPTION
               " A list of cellular QOS entries"
    ::= { ciscoCgwCellMIB 8 }

ciscoCgwCellModemEntry OBJECT-TYPE
    SYNTAX      CiscoCgwCellModemEntry 
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "cellular unit hardware information"
    INDEX       { entPhysicalIndex }
    ::= { ciscoCgwCellModemTable 1 }

ciscoCgwCellModemOdiEntry OBJECT-TYPE
    SYNTAX      CiscoCgwCellModemOdiEntry 
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "cellular Hardware Host information"
    INDEX       { entPhysicalIndex }
    ::= { ciscoCgwCellModemOdiTable 1 }

ciscoCgwCellNetworkEntry OBJECT-TYPE
    SYNTAX      CiscoCgwCellNetworkEntry 
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "cellular Network information"
    INDEX       { entPhysicalIndex }
    ::= { ciscoCgwCellNetworkTable 1 }

ciscoCgwCellProfileEntry OBJECT-TYPE
    SYNTAX      CiscoCgwCellProfileEntry 
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "cellular Profile information"
    INDEX       { entPhysicalIndex, ciscoCgwCellProfileID}
