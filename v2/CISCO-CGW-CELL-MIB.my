ciscoCgwCellMSISDN OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Mobile Subscriber ISD Number"
    ::= { ciscoCgwCellModemEntry 7 }

ciscoCgwCellFSN OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Factory Serial Number"
