ciscoCgwCellFirmwareActMode OBJECT-TYPE 
    SYNTAX     CgwActMode 
    MAX-ACCESS read-only 
    STATUS     current 
    DESCRIPTION
               " Displays Firmware Act Mode"
    ::= { ciscoCgwCellFirmware 1 }

ciscoCgwCellFirmwareTable OBJECT-TYPE 
    SYNTAX     SEQUENCE OF CiscoCgwCellFirmwareEntry
