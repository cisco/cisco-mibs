CiscoCgwCellSimEntry ::= 
SEQUENCE {
         ciscoCgwCellSimStatusSlot0           String,
         ciscoCgwCellSimStatusSlot1           String,
  	 ciscoCgwCellActiveSIM		      INTEGER 
 }

ciscoCgwCellSimStatusSlot0 OBJECT-TYPE
     SYNTAX          String 
     MAX-ACCESS      read-only
     STATUS          current
     DESCRIPTION
        "Sim Status of SIM slot 0"
     ::= { ciscoCgwCellSimEntry 1 }

ciscoCgwCellSimStatusSlot1 OBJECT-TYPE
     SYNTAX          String 
     MAX-ACCESS      read-only
     STATUS          current
     DESCRIPTION
        "Sim Status of SIM slot 1"
     ::= { ciscoCgwCellSimEntry 2 }

 ciscoCgwCellActiveSIM OBJECT-TYPE
     SYNTAX          INTEGER 
     MAX-ACCESS      read-only
     STATUS          current
     DESCRIPTION
         "Shows the active SIM slot number"
     ::= { ciscoCgwCellSimEntry 3 }

CiscoCgwCellRadioEntry ::= 
SEQUENCE {
        cgwCellRadioStatus		CgwRadioStatusEnum,
        cgwCellRATSelected		CgwRATVal,
        cgwCellCurrOperatingBand        INTEGER,
        cgwCellCurrRssi        		INTEGER,
        cgwCellCurrEcio		        INTEGER,
        cgwCellChannelNumber       	INTEGER,	
        cgwCellScramblingCode		INTEGER,
	cgwCellLTETxChannelNumber	INTEGER,
	cgwCellLTERxChannelNumber	INTEGER,
	cgwCellLTEBandwidth		String,
	cgwCellLTECurrRsrp		INTEGER,
	cgwCellLTECurrRsrq	 	INTEGER,	
	cgwCellLTECurrSnr	        String,
	cgwCellLTEPhyCellId	        INTEGER, 	
	cgwCellCAstatus			CgwCAstatusEnum,
	cgwCell5GNRCurrRsrp		INTEGER,
	cgwCell5GNRCurrRsrq		INTEGER,
	cgwCell5GNRMeasuredSinr         String
}

cgwCellRadioStatus OBJECT-TYPE  
     SYNTAX          CgwRadioStatusEnum 
     MAX-ACCESS      read-only
     STATUS          current
     DESCRIPTION "Radio Status "
     ::= { ciscoCgwCellRadioEntry 1 }

cgwCellRATSelected OBJECT-TYPE  
