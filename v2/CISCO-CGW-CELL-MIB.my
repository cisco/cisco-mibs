    ::= { ciscoCgwCellNetworkEntry 6 }

ciscoCgwCellRoamingStatus OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "roaming status" 
