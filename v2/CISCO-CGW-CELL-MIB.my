ciscoCgwCellModemTemperature OBJECT-TYPE
    SYNTAX      Byte
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Current Modem Temperature"
    ::= { ciscoCgwCellModemEntry 9 }

ciscoCgwCellPRISKUID OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION " PRI SKU ID"
    ::= { ciscoCgwCellModemEntry 10 }

ciscoCgwCellPRIVersion OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
