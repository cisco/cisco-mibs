ciscoCgwCellModemOdiTable OBJECT-TYPE 
    SYNTAX     SEQUENCE OF CiscoCgwCellModemOdiEntry
    MAX-ACCESS not-accessible
    STATUS     current
    DESCRIPTION
               " A list of cellular Modem Odi entries"
    ::= { ciscoCgwCellModem 2 }

ciscoCgwCellRadio OBJECT IDENTIFIER 
