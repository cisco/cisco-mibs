CiscoCgwCellProfileEntry ::=
    SEQUENCE {
        ciscoCgwCellProfileID		Unsigned32,
	ciscoCgwCellProfilePDPType  	CgwPdpType,	
	ciscoCgwCellProfileAPNName	String,
	ciscoCgwCellProfileState	CgwActivationEnum,	
	ciscoCgwCellProfileAuthentication CgwAuthType,
	ciscoCgwCellProfileUsername	String,
	ciscoCgwCellProfilePassword	String
    }

ciscoCgwCellProfileID OBJECT-TYPE
    SYNTAX      Unsigned32 
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Profile ID"
    ::= { ciscoCgwCellProfileEntry 1 }

ciscoCgwCellProfilePDPType OBJECT-TYPE 
    SYNTAX      CgwPdpType 
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "PDP Type"
    ::= { ciscoCgwCellProfileEntry 2 }

ciscoCgwCellProfileAPNName OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "APN Name"
    ::= { ciscoCgwCellProfileEntry 3 }

ciscoCgwCellProfileState OBJECT-TYPE
    SYNTAX      CgwActivationEnum 
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Profile PDP state"
    ::= { ciscoCgwCellProfileEntry 4}

ciscoCgwCellProfileAuthentication OBJECT-TYPE
    SYNTAX      CgwAuthType 
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Profile Authentication"
    ::= { ciscoCgwCellProfileEntry 5 }

ciscoCgwCellProfileUsername OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Username"
    ::= { ciscoCgwCellProfileEntry 6 }

ciscoCgwCellProfilePassword OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Password"
    ::= { ciscoCgwCellProfileEntry 7 }

CiscoCgwCellSessionEntry ::=
    SEQUENCE {
        ciscoCgwCellSessionID           Unsigned32, 
        ciscoCgwCellAPN			String,	
	ciscoCgwCellSessionStatus       String,	
 	ciscoCgwCellIPv4Address		IpAddress,
        ciscoCgwCellIPv6Prefix          Ipv6Address,   
        ciscoCgwCellIPv6PrefixLen       Unsigned32,
        ciscoCgwCellIPv4GwAddr          IpAddress,
        ciscoCgwCellIPv6GwPrefix        Ipv6Address,
        ciscoCgwCellIPv6GwPrefixLen     Unsigned32,
        ciscoCgwCellPriDnsIPv4Addr      IpAddress,
        ciscoCgwCellSecDnsIPv4Addr      IpAddress,
        ciscoCgwCellPriDnsIPv6Addr      Ipv6Address,
        ciscoCgwCellSecDnsIPv6Addr      Ipv6Address,
        ciscoCgwCellTxPkts              Counter32,
        ciscoCgwCellRxPkts              Counter32,
        ciscoCgwCellTxBytes             Counter64,
