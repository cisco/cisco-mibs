        ciscoCgwCellMCC                      Unsigned32,
        ciscoCgwCellMNC                      Unsigned32,
        ciscoCgwCellRoamingStatus            String,
        ciscoCgwCellNetwork                  String,
        ciscoCgwCellPSState                  String,
        ciscoCgwCellEMMState                 String,
        ciscoCgwCellEMMSubState              String,
        ciscoCgwCellRRCConnectionState       String,
        ciscoCgwCellTAC                      Unsigned32,
        ciscoCgwCellID                       Unsigned32,
        ciscoCgwCellMTU                      Unsigned32 
    }

