     MAX-ACCESS      read-only
     STATUS          current
     DESCRIPTION "RxChannelNumber "
     ::= { ciscoCgwCellRadioEntry 9 }

cgwCellLTEBandwidth OBJECT-TYPE  
     SYNTAX          String
     MAX-ACCESS      read-only
     STATUS          current
     DESCRIPTION "Bandwidth " 
     ::= { ciscoCgwCellRadioEntry 10 }

cgwCellLTECurrRsrp OBJECT-TYPE  
