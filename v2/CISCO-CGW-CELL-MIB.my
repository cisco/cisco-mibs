CISCO-CGW-CELL-MIB DEFINITIONS ::= BEGIN
IMPORTS
    MODULE-IDENTITY, OBJECT-TYPE,
    Integer32, Unsigned32,
    Counter32, Counter64, Gauge32, IpAddress
        FROM SNMPv2-SMI
    entPhysicalIndex  FROM ENTITY-MIB
    Ipv6Address		    FROM  IPV6-TC
    TEXTUAL-CONVENTION, RowStatus, DateAndTime,
    TruthValue
        FROM SNMPv2-TC
    MODULE-COMPLIANCE, OBJECT-GROUP,
    NOTIFICATION-GROUP      FROM SNMPv2-CONF
    snmpTraps               FROM SNMPv2-MIB
    ciscoMgmt
        FROM CISCO-SMI;


ciscoCgwCellMIB MODULE-IDENTITY
    LAST-UPDATED "202603120000Z"
    ORGANIZATION "Cisco Systems, Inc."
    CONTACT-INFO "Cisco Systems
             Customer Service
 
             Postal: 170 W Tasman Drive
             San Jose, CA  95134
             USA
 
             Tel: +1 800 553-NETS
 
             E-mail: cs-3g@cisco.com
                    cs-4g@cisco.com" 
    DESCRIPTION 
             "THIS MIB module to provide cellularModemTable, Radio, 3G Table entries" 
    REVISION "202603120000Z"
    DESCRIPTION
             "Initial revision of the CISCO-CGW-CELL-MIB module.
              Added support for cellular modem management including:
              - Modem status and configuration
              - Radio signal quality metrics
              - Network registration and connectivity
              - Firmware version and upgrade management
              - Antenna information and signal strength
              - SIM card status and profiles
              - APN configuration and management"
    ::= { ciscoMgmt 1059 }

ciscoCgwCellModem  OBJECT IDENTIFIER
    ::= { ciscoCgwCellMIB 1 }
 
ciscoCgwCellFirmware OBJECT IDENTIFIER 
    ::= { ciscoCgwCellMIB 6 }

Byte ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS      current
    DESCRIPTION "xs:byte"
    SYNTAX      Integer32 (-128 .. 127)

Short ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "d"
    STATUS      current
    DESCRIPTION "xs:short"
    SYNTAX      Integer32 (-32768 .. 32767)

String ::= TEXTUAL-CONVENTION
    DISPLAY-HINT "1t"
    STATUS      current
    DESCRIPTION "xs:string"
    SYNTAX      OCTET STRING

CgwAuthType ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Authentication Type"
    SYNTAX      INTEGER  {none(0),pAP(1),cHAP(2),pAP-CHAP(3)}

CgwPdpType ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular PDP Type"
    SYNTAX      INTEGER  {iPv4(0),iPv6(2),iPv46(3)}

CgwActMode ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Firmware Activation Mode"
    SYNTAX      INTEGER  {manual(0), auto(1)}

CgwActivationEnum ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Profile Activation Mode"
    SYNTAX      INTEGER  {not-activated(0),activated(1)}

CgwStatusEnum ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Firmware Status"
    SYNTAX      INTEGER  {inactive(0),active(1)}

IpVersion ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "IP Version"
    SYNTAX      INTEGER  {ipv4(4),ipv6(6)}

CgwQosState ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Qos Status"
    SYNTAX      INTEGER  {activated(0), modified(1),deleted(2), suspended(3),enabled(4),disabled(5), rebind(6)}

CgwFlowType ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Qos Flow Status"
    SYNTAX      INTEGER  {ue-initiated(0), network-initiated(1)}

Tx-xport-protocol ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Tx Xport protocol Type"
    SYNTAX      INTEGER  {qos-proto-none(0), qos-proto-icmp(1), qos-proto-tcp(6), qos-proto-udp(17), qos-proto-esp(50), qos-proto-ah(51), qos-proto-icmpv6(58)}

Rx-xport-protocol ::= TEXTUAL-CONVENTION
    STATUS      current
    DESCRIPTION "Cellular Tx Xport protocol Type"
    SYNTAX      INTEGER  {qos-proto-none(0), qos-proto-icmp(1), qos-proto-tcp(6), qos-proto-udp(17), qos-proto-esp(50), qos-proto-ah(51), qos-proto-icmpv6(58)}

CiscoWanCellExtRsrp ::= TEXTUAL-CONVENTION
    DISPLAY-HINT    "d"
    STATUS          current
    DESCRIPTION
        "Reference signal received power (RSRP) is
        defined as the linear average over the power
        contributions and measured in dBm. The reporting
        range of RSRP is defined per LTE standard
        with 1 dBm resolution."
    SYNTAX          Integer32

CiscoWanCellExtRsrq ::= TEXTUAL-CONVENTION
    DISPLAY-HINT    "d-1"
    STATUS          current
    DESCRIPTION
        "Reference Signal Received Quality (RSRQ) is
        defined as the ratio NxRSRP over (E-UTRAN carrier RSSI)
        and measured in dB. The reporting range of
        RSRQ is defined per LTE standard with 0.5 dB
        resolution."
    SYNTAX          Integer32

CiscoWanCellExtCqiIndex ::= TEXTUAL-CONVENTION
    DISPLAY-HINT    "d"
    STATUS          current
    DESCRIPTION
        "Channel Quality indicator reported to eNodeB
        which directly translates to Modulation Coding
        Scheme selected."
    SYNTAX          Unsigned32

CiscoWanCellExtSNR ::= TEXTUAL-CONVENTION
    DISPLAY-HINT    "d-1"
    STATUS          current
    DESCRIPTION
        "Signal-to-Noise power Ratio (SNR)
        is defined as the ratio of signal
        power to the noise power, measured
        in dB. It determines the downlink
        throughput for the UE."
    SYNTAX          Integer32

CiscoWanCellExtSINR ::= TEXTUAL-CONVENTION
    DISPLAY-HINT    "d-1"
    STATUS          current
    DESCRIPTION
        "Signal to Interference plus Noise Ratio is
        the power at the receiver due to the required
        signal, divided by the power due to noise and
        interference measured in dB. It is used as a
        measure of signal quality."
    SYNTAX          Integer32

C3gServiceCapability ::= TEXTUAL-CONVENTION
    STATUS          current
    DESCRIPTION
        "3G service capability:
        oneXRtt(0)   - 1xRTT
        evDoRel0(1)  - EVDO Revision 0
        evDoRelA(2)  - EVDO Revision A
        evDoRelB(3)  - EVDO Revision B
        gprs(4)      - GPRS
        edge(5)      - EDGE
        umtsWcdma(6) - UMTS/WCDMA
        hsdpa(7)     - HSDPA
        hsupa(8)     - HSUPA
        hspa(9)      - HSPA
        hspaPlus(10) - HSPA Plus
        lteTdd(11)   - LTE TDD
        lteFdd (12)  - LTE FDD "
    SYNTAX          BITS {
                        oneXRtt(0),
                        evDoRel0(1),
                        evDoRelA(2),
                        evDoRelB(3),
                        gprs(4),
                        edge(5),
                        umtsWcdma(6),
                        hsdpa(7),
                        hsupa(8),
                        hspa(9),
                        hspaPlus(10),
                        lteTdd(11),
                        lteFdd(12)
                    }

C3gRssi ::= TEXTUAL-CONVENTION
    STATUS          current
    DESCRIPTION
        "Generic RSSI range."
    SYNTAX          Integer32 (-150..0)

CgwRadioStatusEnum ::= TEXTUAL-CONVENTION
    STATUS          current
    DESCRIPTION
        " Radio Status"
    SYNTAX      INTEGER  {online(0), offline(3), low-power(1)}

CgwRATVal ::= TEXTUAL-CONVENTION
    STATUS          current
    DESCRIPTION
        " RAT Value"
    SYNTAX      INTEGER  {unknown(0), 
			  lte(1), 
		          umts(2),
		   	  nsa(3),
			  sa(4)}

CgwCAstatusEnum ::= TEXTUAL-CONVENTION
    STATUS          current
    DESCRIPTION
        " CA status "
    SYNTAX      INTEGER  {disabled(0), 
                          enabled(1)}

C3gEcIo ::= TEXTUAL-CONVENTION
    STATUS          current
    DESCRIPTION
        "Generic EcIo range."
    SYNTAX          Integer32 (-150..0)

ciscoCgwCellModemTable OBJECT-TYPE 
