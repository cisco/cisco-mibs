    ::= { ciscoCgwCellModemEntry 3 }

ciscoCgwCellIMSI OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "International Mobile Subscriber Identity"
    ::= { ciscoCgwCellModemEntry 4  }

ciscoCgwCellIMEI OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "International Mobile Equipment Identity (IMEI)"
    ::= { ciscoCgwCellModemEntry 5 }

ciscoCgwCellICCID OBJECT-TYPE
    SYNTAX      String
    MAX-ACCESS  read-only
