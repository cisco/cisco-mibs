    ::= { fields 31 }

cgwIpsecDstAddr OBJECT-TYPE
    SYNTAX      OCTET STRING 
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION ""
    ::= { fields 32 }

-- Notification definitions
cgwInterfaceAdminStateChange NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwIfName,
		cgwNewAdminState
	}
	STATUS current
	DESCRIPTION "Interface state has changed"
	::= { traps 1 }

cgwInterfaceOperStateChange NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwIfName,
		cgwNewOperState
	}
	STATUS current
	DESCRIPTION "Interface state has changed"
	::= { traps 2 }

cgwImageUpgrade NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
                cgwUpgradeStatus,
                cgwOldVersion,
                cgwNewVersion
	}
	STATUS current
	DESCRIPTION "Image upgraded"
	::= { traps 3 }

cgwModemFirmwareUpgrade NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwFwUpgradeStatus,
		cgwFwOldVersion,
                cgwFwNewVersion
	}
	STATUS current
	DESCRIPTION "Modem Firmware upgraded"
	::= { traps 4 }

cgwInterfaceIpAddrChange NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwIfName,
                cgwOldIpAddr,
		cgwNewIpAddr,
                cgwOldSubMask,
                cgwNewSubMask
	}
	STATUS current
	DESCRIPTION "Interface IP changed"
	::= { traps 5 }

cgwSimStatusSwitchOver NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwSimStatus,
		cgwSimOldSlot,
		cgwSimNewSlot
	}
	STATUS current
	DESCRIPTION "Sim status switched over"
	::= { traps 6 }

cgwModemStatusChange NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwModemStatus
	}
	STATUS current
	DESCRIPTION "Modem state has changed"
	::= { traps 7 }

cgwNetworkStatus NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwRATChange
	}
	STATUS current
	DESCRIPTION "Network state has changed"
	::= { traps 8 }

cgwRebootReason NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwRebootReasonType
	}
	STATUS current
	DESCRIPTION "Reboot reason type"
	::= { traps 9 }

cgwLoginNotify NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwLoginStatus,
		cgwSystemUserName
	}
	STATUS current
	DESCRIPTION "Login Notify"
	::= { traps 10 }

cgwWanSwitchOver NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
                cgwIfName,
                cgwIfStatus,
                cgwIpAddr,
                cgwActiveIf,
                cgwStandByIf 
	}
	STATUS current
	DESCRIPTION "Wan SwitchOver"
	::= { traps 11 }

cgwIpsecStatusChange NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwIpsecStatus,
		cgwIpsecTunnelName,
		cgwIpsecSrcAddr,
                cgwIpsecDstAddr
	}
	STATUS current
	DESCRIPTION "IPsec status changed"
	::= { traps 12 }

cgwIpsecTunnelSwithOver NOTIFICATION-TYPE
	OBJECTS {
                eventTime,
                netconfNotificationSeverity, 
		cgwIpsecStatus,
		cgwIpsecTunnelName,
		cgwIpsecSrcAddr,
                cgwIpsecDstAddr
	}
	STATUS current
	DESCRIPTION "IPsec Tunnel Switchover"
	::= { traps 13 }

END
